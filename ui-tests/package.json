{
  "name": "@jupyter-notebook/ui-tests",
  "private": true,
  "version": "0.1.0",
  "author": "Project Jupyter",
  "license": "BSD-3-Clause",
  "description": "Jupyter Notebook UI Tests",
  "scripts": {
    "deduplicate": "jlpm dlx yarn-berry-deduplicate -s fewerHighest && jlpm install",
    "rimraf": "rimraf",
    "start": "jupyter notebook --config test/jupyter_server_config.py",
    "test": "playwright test",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:report": "http-server ./playwright-report -a localhost -o",
    "test:update": "playwright test --update-snapshots",
    "test:collaboration": "playwright test --grep=@collaboration",
    "test:collaboration:multi-user": "playwright test --grep=@multi-user --workers=1",
    "test:collaboration:performance": "playwright test --grep=@performance --timeout=60000",
    "test:collaboration:debug": "PWDEBUG=1 playwright test --grep=@collaboration"
  },
  "dependencies": {
    "@jupyterlab/galata": "~5.5.0-alpha.0",
    "@playwright/test": "~1.52.0",
    "rimraf": "^3.0.2"
  }
}
