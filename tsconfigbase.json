{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "declaration": true,
    "esModuleInterop": true,
    "incremental": true,
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "preserveWatchOutput": true,
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "ES2018",
    "types": [],
    "lib": ["DOM", "DOM.Iterable", "ES2018", "ES2020.Intl"]
  },
  "include": [
    "src/**/*",
    "packages/*/src/**/*",
    "packages/notebook/src/collab/**/*",
    "packages/notebook-extension/src/components/**/*",
    "typings/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "lib",
    "*.min.js",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "coverage",
    "**/*.d.ts"
  ]
}
